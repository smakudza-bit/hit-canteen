# Render production example for HIT Canteen
# Replace YOUR-RENDER-SERVICE with your actual Render hostname.

DJANGO_SECRET_KEY=replace-with-generated-django-secret
DEBUG=false
TIME_ZONE=Africa/Harare

# Aiven PostgreSQL
DATABASE_URL=postgresql://USERNAME:PASSWORD@HOST:PORT/DATABASE?sslmode=require

# Auth and ticket
ACCESS_TOKEN_MINUTES=60
HIT_TICKET_SECRET=replace-with-generated-ticket-secret

# Render host and security
EXTRA_ALLOWED_HOSTS=YOUR-RENDER-SERVICE.onrender.com
CSRF_TRUSTED_ORIGINS_EXTRA=https://YOUR-RENDER-SERVICE.onrender.com
CORS_ALLOWED_ORIGINS=
CORS_ALLOW_CREDENTIALS=false
SECURE_SSL_REDIRECT=true

# Payment webhook secrets
WEBHOOK_SECRET_MOBILE_MONEY=replace-with-mobile-money-webhook-secret
WEBHOOK_SECRET_BANK_CARD=replace-with-bank-card-webhook-secret
WEBHOOK_SECRET_ONLINE_PAYMENT=replace-with-online-payment-webhook-secret

# Paynow
PAYNOW_INTEGRATION_ID=23824
PAYNOW_INTEGRATION_KEY=52ed5a83-8b9c-4f10-bbd0-8c4e1c5fccec
PAYNOW_RESULT_URL=https://YOUR-RENDER-SERVICE.onrender.com/api/v1/payments/paynow/result
PAYNOW_RETURN_URL=https://YOUR-RENDER-SERVICE.onrender.com/student/
PAYNOW_INITIATE_URL=https://www.paynow.co.zw/interface/initiatetransaction
PAYNOW_INCLUDE_AUTH_EMAIL=true

# Email
EMAIL_NOTIFICATIONS_ENABLED=true
EMAIL_BACKEND=django.core.mail.backends.smtp.EmailBackend
EMAIL_HOST=smtp.gmail.com
EMAIL_PORT=587
EMAIL_HOST_USER=replace-with-smtp-username
EMAIL_HOST_PASSWORD=replace-with-smtp-password-or-app-password
EMAIL_USE_TLS=true
EMAIL_USE_SSL=false
DEFAULT_FROM_EMAIL=replace-with-sender-email@example.com
WORK_NOTIFICATION_EMAIL=replace-with-your-work-email@example.com
